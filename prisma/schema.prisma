generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  // Non-enumerable public identifier — what the JWT/session carries instead of
  // the sequential Int PK. DB-generated (see prisma/migrations-manual).
  publicId     String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role         String   @default("admin")
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Post {
  id            Int       @id @default(autoincrement())
  // Non-enumerable public identifier used in admin URLs/APIs instead of the Int PK.
  publicId      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String
  locale        String    @default("en") // "en" | "fa" — which localized blog a post belongs to
  title         String
  excerpt       String
  content       String    @db.Text
  coverImageUrl String?
  tags          String[]  @default([])
  dir           String    @default("ltr") // "ltr" | "rtl" — text direction for RTL (Persian) posts
  draft         Boolean   @default(true)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // A slug is unique within a locale, so en & fa can share the same slug
  // (e.g. /en/blog/x and /fa/blog/x are the two translations of one post).
  @@unique([slug, locale])

  // Per-post SEO controls (all optional; owner-authored, see PostForm "SEO & Social")
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  jsonLd          String?  @db.Text
  headHtml        String?  @db.Text
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  // Non-enumerable public identifier used by the admin mark-read action.
  publicId  String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  service   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
